# AEO Agent — environment variables
# Copy this file to `.env` and fill in your real keys.
# Never commit `.env` to git.

# --- Required: Scrapfly (https://scrapfly.io) ---
# Used to bypass Cloudflare, render JS, and scrape protected sites.
SCRAPFLY_API_KEY=your_scrapfly_key_here

# --- Required: Z.ai / ZhipuAI (https://open.bigmodel.cn) ---
# OpenAI-compatible endpoint used for all AI scoring + content generation.
Z_AI_API_KEY=your_z_ai_key_here

# --- Optional: Z.ai overrides (defaults work for most users) ---
# Z_AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Z_AI_MODEL=glm-4.5-flash

# --- Optional: Flask server config ---
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# FLASK_DEBUG=false
# SECRET_KEY=change-me-in-production

# --- Optional: logging ---
# LOG_LEVEL=INFO
